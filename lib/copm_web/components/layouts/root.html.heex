<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()} />
    <link rel="icon" type="image/png" href={~p"/settings.png"} />
    <title>Copm</title>
    <script>
      (function () {
        var stored = localStorage.getItem("copm-theme");
        document.documentElement.dataset.theme = stored === "light" ? "light" : "dark";
      })();
      window.copmToggleTheme = function () {
        var root = document.documentElement;
        var next = root.dataset.theme === "dark" ? "light" : "dark";
        root.dataset.theme = next;
        localStorage.setItem("copm-theme", next);
      };
    </script>
    <script defer src={~p"/js/phoenix_html.js"}>
    </script>
    <script defer src={~p"/js/phoenix.min.js"}>
    </script>
    <script defer src={~p"/js/phoenix_live_view.min.js"}>
    </script>
  </head>
  <body>
    {@inner_content}
    <script>
      window.addEventListener("DOMContentLoaded", () => {
        let csrfToken = document
          .querySelector("meta[name='csrf-token']")
          .getAttribute("content");

        let Hooks = {
          AutoDismissFlash: {
            mounted() {
              this.timer = setTimeout(() => this.el.click(), 4000);
            },
            destroyed() {
              clearTimeout(this.timer);
            }
          },
          SidebarResizer: {
            mounted() {
              const resizer = this.el;
              const sidebar = document.getElementById("sidebar");
              const minWidth = 280;
              const maxWidth = 800;
              let isResizing = false;

              const stored = parseInt(localStorage.getItem("copm-sidebar-width"), 10);
              if (sidebar && !Number.isNaN(stored)) {
                sidebar.style.width = `${Math.min(Math.max(stored, minWidth), maxWidth)}px`;
              }

              this.onMouseDown = () => {
                isResizing = true;
                resizer.classList.add("resizing");
                document.body.style.cursor = "col-resize";
                document.body.style.userSelect = "none";
              };

              this.onMouseMove = (e) => {
                if (!isResizing || !sidebar) return;
                let newWidth = e.clientX;
                if (newWidth < minWidth) newWidth = minWidth;
                if (newWidth > maxWidth) newWidth = maxWidth;
                sidebar.style.width = `${newWidth}px`;
              };

              this.onMouseUp = () => {
                if (isResizing) {
                  isResizing = false;
                  resizer.classList.remove("resizing");
                  document.body.style.cursor = "default";
                  document.body.style.removeProperty("user-select");
                  if (sidebar) localStorage.setItem("copm-sidebar-width", parseInt(sidebar.style.width, 10));
                }
              };

              resizer.addEventListener("mousedown", this.onMouseDown);
              document.addEventListener("mousemove", this.onMouseMove);
              document.addEventListener("mouseup", this.onMouseUp);
            },
            destroyed() {
              document.removeEventListener("mousemove", this.onMouseMove);
              document.removeEventListener("mouseup", this.onMouseUp);
            }
          }
        };

        let liveSocket = new window.LiveView.LiveSocket("/live", window.Phoenix.Socket, {
          params: { _csrf_token: csrfToken },
          hooks: Hooks
        });

        liveSocket.connect();
        window.liveSocket = liveSocket;
      });
    </script>
  </body>
</html>
